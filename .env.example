KARAOKE_FORGE_ROOT=/mnt/scripts/karaoke-forge
KARAOKE_FORGE_BASE_PATH=/karaoke-forge
KARAOKE_FORGE_LIBRARY=/mnt/scripts/karaoke-forge/library
KARAOKE_FORGE_DB=/mnt/scripts/karaoke-forge/library/karaoke_forge.sqlite3
KARAOKE_GEN_BIN=karaoke-gen

# whisper-timestamped uses OpenAI Whisper model names. Use large-v3, not openai/whisper-large-v3.
WHISPER_MODEL_SIZE=large-v3
WHISPER_DEVICE=cuda
# Force English. Auto-detect can hallucinate Welsh/other languages on slow vocals.
WHISPER_LANGUAGE=en
ENABLE_LOCAL_WHISPER=true
CUDA_VISIBLE_DEVICES=0

# Heavier spaCy model for phrase/natural-break analysis paths that honor a spaCy model env.
SPACY_MODEL=en_core_web_md

# Safer defaults for indie karaoke output.
# clean avoids unstable lead-vocal leakage from backing-vocal stems.
KARAOKE_DEFAULT_INSTRUMENTAL_SELECTION=clean
# Positive value delays karaoke highlights if Whisper timing fires early (milliseconds).
KARAOKE_DEFAULT_SUBTITLE_OFFSET_MS=500

# Patch karaoke-gen OutputConfig so final render keeps subtitle_offset_ms (see sitecustomize.py).
KARAOKE_FORGE_PATCH_KARAOKE_GEN=1

# Optional: snap per-word timings to vocal-stem energy at review complete (default off).
KARAOKE_FORGE_VOCAL_TIMING=1
# KARAOKE_FORGE_VOCAL_TIMING_FRAME_MS=50
# KARAOKE_FORGE_VOCAL_TIMING_SNAP_MS=150
# KARAOKE_FORGE_VOCAL_TIMING_MAX_DRIFT_MS=200

# Optional: Winamp-style vocal activity bar on final MP4 via ffmpeg (default off).
KARAOKE_FORGE_VOCAL_VISUALIZER=1

# Theme JSON (karaoke-gen styles) lead-in keys for inline per-line cues:
#   lead_in_preview_seconds (default 2.0) — how long before first-word highlight
#   lead_in_min_gap (default 0.3) — minimum gap from previous line to show lead-in
