KARAOKE_FORGE_ROOT=/mnt/scripts/karaoke-forge
KARAOKE_FORGE_BASE_PATH=/karaoke-forge
KARAOKE_FORGE_LIBRARY=/mnt/scripts/karaoke-forge/library
KARAOKE_FORGE_DB=/mnt/scripts/karaoke-forge/library/karaoke_forge.sqlite3
KARAOKE_GEN_BIN=karaoke-gen
WHISPER_MODEL_SIZE=medium
WHISPER_DEVICE=cuda
ENABLE_LOCAL_WHISPER=true
CUDA_VISIBLE_DEVICES=0

# Safer defaults for indie karaoke output.
# clean avoids unstable lead-vocal leakage from backing-vocal stems.
KARAOKE_DEFAULT_INSTRUMENTAL_SELECTION=clean
# Positive delays highlights if Whisper timing fires early.
KARAOKE_DEFAULT_SUBTITLE_OFFSET_MS=300
